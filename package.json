{
  "name": "ohmyvoice",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Push-to-talk voice input daemon for omarchy",
  "license": "MIT",
  "bin": {
    "voicectl": "dist/cli.js",
    "voice-daemon": "dist/daemon.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "tsx --test src/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.1"
  }
}
